# ----------------------------------------------------------------------------
# Maven Start Up Batch script
# Required ENV vars:
# ------------------
#   JAVA_HOME - location of a JDK home dir
# Optional ENV vars
# -----------------
#   MAVEN_OPTS - parameters passed to the Java VM when running Maven
# ----------------------------------------------------------------------------

if [ -z "$JAVA_HOME" ] ; then
  JAVACMD=java
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

# Find the project home directory
MAVEN_PROJECTBASEDIR="${BASH_SOURCE[0]}"
if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  MAVEN_PROJECTBASEDIR="$0"
fi
MAVEN_PROJECTBASEDIR="$(cd "$(dirname "$MAVEN_PROJECTBASEDIR")" && pwd)"

# Download and use Maven wrapper jar
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

DISTRIBUTION_URL=$(grep "distributionUrl" "$WRAPPER_PROPERTIES" | cut -d= -f2- | tr -d '\r')
WRAPPER_URL=$(grep "wrapperUrl" "$WRAPPER_PROPERTIES" | cut -d= -f2- | tr -d '\r')

if [ ! -f "$WRAPPER_JAR" ]; then
  if command -v curl > /dev/null; then
    curl -fsSL -o "$WRAPPER_JAR" "$WRAPPER_URL"
  elif command -v wget > /dev/null; then
    wget -q -O "$WRAPPER_JAR" "$WRAPPER_URL"
  else
    echo "Neither curl nor wget found. Cannot download Maven wrapper."
    exit 1
  fi
fi

MAVEN_HOME="${MAVEN_USER_HOME:-${HOME}/.m2/wrapper/dists}"
DISTRIBUTION_NAME=$(basename "$DISTRIBUTION_URL" .zip)
MAVEN_DIST="$MAVEN_HOME/$DISTRIBUTION_NAME"

if [ ! -d "$MAVEN_DIST" ]; then
  mkdir -p "$MAVEN_HOME"
  TMP_DOWNLOAD="$MAVEN_HOME/tmp-download.zip"
  if command -v curl > /dev/null; then
    curl -fsSL -o "$TMP_DOWNLOAD" "$DISTRIBUTION_URL"
  elif command -v wget > /dev/null; then
    wget -q -O "$TMP_DOWNLOAD" "$DISTRIBUTION_URL"
  fi
  unzip -q "$TMP_DOWNLOAD" -d "$MAVEN_HOME"
  rm -f "$TMP_DOWNLOAD"
fi

MAVEN_CMD="$MAVEN_DIST/bin/mvn"
exec "$MAVEN_CMD" "$@"
